# PoHorseRace — .gitignore
# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite build output
dist/
dist-ssr/

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/

# TypeScript incremental
*.tsbuildinfo

# Playwright test artifacts
test-results/
playwright-report/
.playwright-mcp/

# Specify/speckit scaffolding (AI workflow templates - not app code)
.specify/
specs/

# Prettier config (project-specific, not needed in repo)
.prettierrc
.prettierignore

# ESLint flat config (generated)
eslint.config.js

# GitHub AI agent templates (not CI/CD)
.github/agents/
.github/prompts/

# Local env overrides
*.local
